{
  "name": "tiptap-nodes",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./index.css": "./dist/index.css",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./code-block": {
      "types": "./dist/code-block/index.d.ts",
      "import": "./dist/code-block/index.js",
      "require": "./dist/code-block/index.cjs"
    },
    "./speaker": {
      "types": "./dist/speaker/index.d.ts",
      "import": "./dist/speaker/index.js",
      "require": "./dist/speaker/index.cjs"
    },
    "./image-upload": {
      "types": "./dist/image-upload/index.d.ts",
      "import": "./dist/image-upload/index.js",
      "require": "./dist/image-upload/index.cjs"
    },
    "./image": {
      "types": "./dist/image/index.d.ts",
      "import": "./dist/image/index.js",
      "require": "./dist/image/index.cjs"
    },
    "./gradient-highlight": {
      "types": "./dist/gradient-highlight/index.d.ts",
      "import": "./dist/gradient-highlight/index.js",
      "require": "./dist/gradient-highlight/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "eslint ./src --fix --quiet",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.13.0",
    "comps": "workspace:*",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "nanoid": "^5.1.7",
    "styles": "workspace:*",
    "tiptap-comps": "workspace:*",
    "tiptap-utils": "workspace:*",
    "utils": "workspace:*"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.13.0",
    "@tiptap/extension-highlight": "^3.13.0",
    "@tiptap/markdown": "^3.13.0",
    "@tiptap/pm": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "i18n": "workspace:*",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.7"
  }
}
